# ============================================================
# SemantiCite.ai — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to git!
# ============================================================

# --- Semantic Scholar API ---
# Optional but recommended (increases rate limit from 1 to 100 req/sec)
# Get yours at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# --- Neo4j Graph Database ---
# Option A: Neo4j AuraDB Free (recommended for getting started)
#   Sign up at: https://neo4j.com/cloud/aura-free/
#   URI format: neo4j+s://xxxxxxxx.databases.neo4j.io
# Option B: Local Docker
#   URI format: bolt://localhost:7687
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Google Gemini LLM ---
# Get your free API key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Optional Overrides ---
# LLM_MODEL_NAME=gemini-2.0-flash
# FRONTEND_URL=http://localhost:5173
# DEFAULT_CRAWL_DEPTH=2
# MAX_SEED_PAPERS=10
# MAX_CITATIONS_PER_PAPER=20
